// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: npx create-db

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  COMPANY
  APPLICANT
  STAFF
}

enum PermissionLevel {
  ADMIN
  MODERATOR
  VIEWER
}

model User {
  id              Int     @id @default(autoincrement())
  email           String  @unique
  name            String
  password        String
  role            Role
  permissionLevel PermissionLevel?  // null for APPLICANT/COMPANY, set for MEMBERS
  createdBy       Int?               // who created this user (for audit)
  emailVerified   DateTime?          // null = not yet verified; set when user clicks verification link
  isActive        Boolean  @default(true) // false = suspended/banned
  staff           Staff?
  applications    Application[]
  tasks           Task[]
  verificationTokens VerificationToken[]
  createdAt       DateTime @default(now())
}

// Staff accounts created by the Owner for dashboard management
// Each staff has a role (ADMIN/MODERATOR/VIEWER) and granular permissions
model Staff {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String   @default("VIEWER")  // ADMIN, MODERATOR, VIEWER
  permissions   String   @default("[]")      // JSON array of permission keys
  isSuspended   Boolean  @default(false)
  createdBy     Int      // Owner who created this staff
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Platform activity feed — tracks all significant events
model Activity {
  id        Int      @id @default(autoincrement())
  type      String   // signup, application, payment, task, announcement, system
  action    String   // created, updated, deleted, suspended, etc.
  entity    String   // user, company, internship, application, subscription
  entityId  Int?
  details   String?  // JSON with additional context
  userId    Int?     // who performed the action
  createdAt DateTime @default(now())
}

// Audit log — tracks owner/staff actions for compliance
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      // who performed the action
  action    String   // user.suspend, company.delete, settings.update, etc.
  target    String?  // what was affected (e.g., "user:123", "company:45")
  details   String?  // JSON with before/after values
  ipAddress String?
  createdAt DateTime @default(now())
}

// Platform settings — persisted in database instead of client-side
model PlatformSettings {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  value         String
  updatedAt     DateTime @updatedAt
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  industry    String
  website     String?
  location    String?          // City/Country (e.g. "Manila, Philippines")
  description String?          // Short company bio
  logoUrl     String?          // Company logo file path
  userId      Int     @unique
  internships Internship[]
  tasks       Task[]
  announcements Announcement[]
  subscriptions Subscription[]
  createdAt   DateTime @default(now())
}

// model for Internship Posting
// company relation is declared by company Company 
// enable to 1 company to multiple internship

model Internship {
  id Int @id @default(autoincrement())
  title String
  description String
  slots Int
  deadline DateTime 
  companyId Int 
  company Company  @relation(fields: [companyId], references: [id])
  applications Application[] // create relation to Application model
  createdAt DateTime @default(now())
}

enum Status {
  APPLIED
  REVIEWED
  INTERVIEW
  ACCEPTED
  REJECTED
  CANCELLED    // Intern was cancelled by the company (e.g., performance issues)
  COMPLETED    // Intern finished their required hours (offboarded)
}

model Application {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references:[id])
  internshipId Int
  internship Internship @relation(fields: [internshipId], references: [id])
  status Status
  resumeUrl String?
  startDate DateTime? // Set when status is ACCEPTED — triggers transfer to Interns page
  offboardedAt DateTime? // Set when status is COMPLETED — triggers 30-day retention then auto-delete
  documents Document[]
  appliedAt DateTime @default(now())

  @@unique([userId, internshipId])
}

model Document {
  id Int @id @default(autoincrement())
  applicationId Int
  application Application @relation(fields: [applicationId], references: [id]) // create relation to application model
  fileName String
  fileUrl String
  createdAt DateTime @default(now())
}

enum taskStatus {
  ACCEPTED
  ONGOING
  COMPLETED
}

model Task {
  id Int @id @default(autoincrement())
  title String 
  description String
  deadline DateTime
  status taskStatus
  assignedTo Int
  user User @relation(fields: [assignedTo], references: [id]) // linked to User model
  companyId Int
  company Company @relation(fields: [companyId], references: [id]) // linked to Company model
  reviewedAt DateTime? // Set when manager accepts the completed task
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Updated when status changes (e.g., returned to ongoing)
}

model Announcement {
  id Int @id @default(autoincrement())
  title String
  content String
  companyId Int
  company Company @relation(fields: [companyId], references: [id]) // linked to Company model
  createdAt DateTime @default(now())
}

enum Plan {
  FREE 
  BASIC 
  PRO  
}

enum planStatus {
  ACTIVE
  EXPIRED
}

model Subscription {
  id Int @id @default(autoincrement())
  companyId Int @unique
  company Company @relation(fields: [companyId], references: [id]) // linked to Company model
  plan Plan
  status planStatus
  expiredAt DateTime 
  createdAt DateTime @default(now())
}

// Email verification tokens
// Generated when a user registers — expires after 7 days
// Auto-deleted when user verifies or during cleanup

model VerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime // 7 days from creation
  createdAt DateTime @default(now())
}
